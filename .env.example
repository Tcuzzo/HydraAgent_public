# Hydra environment variables — copy to .env and fill in your values.
# All variables are optional unless marked REQUIRED.

# ── Core paths ───────────────────────────────────────────────────────────────

# Path to hydra.yaml config (default: ~/.hydra/hydra.yaml)
HYDRA_CONFIG=

# Default filesystem root for tool operations (default: current working directory)
HYDRA_DEFAULT_ROOT=

# Directory where .env.* provider files are loaded from (default: ~/.hydraAgent/workspace)
HYDRA_ENV_DIR=

# Path to skills root override
HYDRA_SKILLS_ROOT=

# Path to the sqlite-vec database for unified memory
HYDRA_VEC0_PATH=

# Checkpoint directory for agent runs
HYDRA_CHECKPOINTS_DIR=

# ── Agent runtime ────────────────────────────────────────────────────────────

# Maximum iterations for the ask/agent loop
HYDRA_ASK_MAX_ITERATIONS=

# Session history limit (how many turns to keep)
HYDRA_SESSION_HISTORY_LIMIT=

# Approval/automation policy: allow | yolo | confirm
HYDRA_AUTOMATION_POLICY=

# Sudo-level policy override
HYDRA_SUDO_POLICY=

# Launch the TUI on startup (1 = yes)
HYDRA_LAUNCH_TUI=

# Use legacy REPL mode (1 = yes)
HYDRA_LEGACY_REPL=

# Trace ID for correlated multi-agent runs (set by orchestrator)
HYDRA_TRACE_ID=

# Worktree path (set by worktree-based workflows)
HYDRA_WORKTREE=

# Parent Telegram message ID for threaded replies
HYDRA_PARENT_MESSAGE_ID=

# Internal: suppressed tool output (set by runtime)
HYDRA_SUPPRESSED=
HYDRA_SUPPRESSED_PENDING_TOOL_JSON=

# Target name / type for directed agent runs
HYDRA_TARGET=
HYDRA_TARGET_TYPE=

# ── Operator identity ────────────────────────────────────────────────────────

# Human-readable name for the operator (used in memory/identity text)
HYDRA_OPERATOR_NAME=

# Telegram username of the operator (without @)
HYDRA_OPERATOR_USERNAME=

# Directory for operator auth tokens
HYDRA_OPERATOR_AUTH_DIR=

# ── Fabric / multi-agent ─────────────────────────────────────────────────────

# Base URL of the agent coordination bus (e.g. http://127.0.0.1:8702).
# If unset, coordination routing is disabled.
HYDRA_FABRIC_BASE=

# HTTP workbench API base URL
HYDRA_WORKBENCH_API=

# ── Telegram gateway ─────────────────────────────────────────────────────────

# REQUIRED for Telegram: your bot token from @BotFather
HYDRA_TELEGRAM_BOT_TOKEN=
# Alias also accepted:
# TELEGRAM_BOT_TOKEN=

# Operator DM chat ID (private chat with the operator)
HYDRA_OPERATOR_DM_CHAT_ID=
# Alias also accepted:
# TELEGRAM_CHAT_ID=

# Bot username (without @) for mention detection
HYDRA_TELEGRAM_BOT_USERNAME=

# Group chat ID (optional — for the Telegram group relay)
HYDRA_GROUP_CHAT_ID=

# Test stubs (for unit tests — do not set in production)
# HYDRA_TELEGRAM_FAKE_GETUPDATES=
# HYDRA_TELEGRAM_FAKE_SENDMESSAGE=
# HYDRA_TELEGRAM_FAKE_GETME=
# HYDRA_TELEGRAM_FAKE_ANSWER_CALLBACK=

# ── Ollama providers ─────────────────────────────────────────────────────────

# Local Ollama (default: http://localhost:11434, no auth required)
OLLAMA_ENDPOINT=
OLLAMA_API_KEY=
OLLAMA_MODEL=

# Cloud Ollama (key REQUIRED for cloud provider)
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=
# Aliases:
# OLLAMA_CLOUD_ENDPOINT=
# OLLAMA_BASE_URL=

# ── GPU / hardware ────────────────────────────────────────────────────────────

# Path to the local GPU lease file (default: ~/.cache/gpu.lease)
GPU_LEASE_PATH=


# Force local GPU routing (1 = yes)
HYDRA_LOCAL_GPU=

# Consent flag for large model downloads (set to "yes" to allow)
HYDRA_DOWNLOAD_CONSENT=

# ── Go / browser ─────────────────────────────────────────────────────────────

# Path to the Hydra Go binary (default: resolved from PATH)
HYDRA_GO_BINARY=

# Path to Chrome/Chromium for browser tools
HYDRA_CHROME_PATH=

# ── Sandbox ───────────────────────────────────────────────────────────────────

# Enable container sandbox for bash tool (set to "1" to enable)
HYDRA_EXEC_SANDBOX=

# Container image for the sandbox (default: docker.io/library/python:3.11-slim)
HYDRA_SANDBOX_IMAGE=

# Extra bind mounts for the sandbox (colon-separated host:container pairs)
HYDRA_SANDBOX_EXTRA_MOUNTS=

# ── Chat budget ───────────────────────────────────────────────────────────────

# Path to the chat budget JSONL file
HYDRA_CHAT_BUDGET_PATH=

# Daily chat budget (in tokens or dollars, depending on provider)
HYDRA_CHAT_DAILY_BUDGET=
